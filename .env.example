# ─── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.umrahtransport.me
NEXT_PUBLIC_WHATSAPP_NUMBER=447456938750
NEXT_PUBLIC_BUSINESS_EMAIL=info@umrahtransport.me
NEXT_PUBLIC_BUSINESS_PHONE=+447456938750

# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
POSTGRES_PRISMA_URL=postgresql://USER:PASS@HOST/DB?connect_timeout=15&sslmode=require

# ─── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=                           # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=https://www.umrahtransport.me

# ─── Admin ─────────────────────────────────────────────────────────────────────
# REQUIRED: lib/admin/auth.ts throws at module load if any of the three are missing.
ADMIN_EMAIL=admin@umrahtransport.me    # REQUIRED
ADMIN_PASSWORD=                        # REQUIRED — strong password, no fallback
ADMIN_JWT_SECRET=                      # REQUIRED — openssl rand -base64 32
ADMIN_ALERT_EMAIL=admin@umrahtransport.me   # Receives new booking alerts
ADMIN_WHATSAPP_NUMBER=447456938750     # Admin WhatsApp for booking alerts (with country code, no +)

# ─── Vendor auth ───────────────────────────────────────────────────────────────
VENDOR_JWT_SECRET=                     # REQUIRED — openssl rand -base64 32

# ─── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe Dashboard → Webhooks → your endpoint

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password            # Gmail: use App Password (16-char), not account password
SMTP_FROM=Umrah Transport <noreply@umrahtransport.me>

# ─── WhatsApp Business (Meta Cloud API) ───────────────────────────────────────
# Get from Meta for Developers → WhatsApp → API Setup
# Phone number: +44 7456 938750 — used for outgoing notifications and inbound auto-replies
WHATSAPP_API_TOKEN=                    # Permanent system user token from Meta Business Suite
WHATSAPP_PHONE_NUMBER_ID=              # Phone number ID from Meta → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=                 # Any random string — must match what you enter in Meta webhook settings
