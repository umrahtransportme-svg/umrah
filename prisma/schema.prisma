generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContentBlock {
  id        String   @id @default(cuid())
  page      String
  section   String
  key       String
  value     String   @db.Text
  type      String   @default("text")
  label     String   @default("")
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([page, section, key])
  @@map("content_blocks")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  googleId       String?   @unique
  phone          String?
  nationality    String?
  dateOfBirth    String?
  profilePicture String?   @db.Text
  referralCode   String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  passport   PassportDetail?
  bookings   Booking[]
  savedCards SavedCard[]
  complaints Complaint[]
  referrals  Referral[]  @relation("ReferrerReferrals")

  @@map("users")
}

model PassportDetail {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String   @default("")
  passportNumber String   @default("")
  nationality    String   @default("")
  dateOfBirth    String   @default("")
  issueDate      String   @default("")
  expiryDate     String   @default("")
  updatedAt      DateTime @updatedAt

  @@map("passport_details")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  iconName    String
  enabled     Boolean  @default(true)
  description String
  pricing     Json
  colorClass  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Booking {
  id               String          @id @default(cuid())
  reference        String          @unique
  status           String          @default("pending")
  serviceType      String
  pickupLocation   String
  dropoffLocation  String
  travelDate       String
  passengers       Int
  vehicleType      String
  customerName     String
  customerEmail    String
  customerWhatsapp String
  customerCountry  String
  totalAmount      Float           @default(0)
  vendorAmount     Float           @default(0)
  driverId         String?
  notes            String?
  userId           String?
  vendorId         String?
  refunded         Boolean         @default(false)
  refundAmount     Float           @default(0)
  user             User?           @relation(fields: [userId], references: [id])
  vendor           VendorAccount?  @relation(fields: [vendorId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("bookings")
}

model VendorAccount {
  id             String    @id @default(cuid())
  companyName    String
  contactName    String
  email          String    @unique
  phone          String?
  passwordHash   String
  status         String    @default("pending")
  city           String?
  country        String    @default("Saudi Arabia")
  commissionRate Float     @default(15)
  payoutMethod   String    @default("bank")
  payoutDetails  Json      @default("{}")
  payoutSchedule String    @default("monthly")
  payoutDay      Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bookings  Booking[]
  payouts   Payout[]
  vehicles  VendorVehicle[]
  drivers   VendorDriver[]
  documents VendorDocument[]

  @@map("vendor_accounts")
}

model Payout {
  id        String        @id @default(cuid())
  vendorId  String
  vendor    VendorAccount @relation(fields: [vendorId], references: [id])
  amount    Float
  currency  String        @default("GBP")
  status    String        @default("pending")
  method    String
  reference String?
  period    String?
  notes     String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("payouts")
}

model VendorVehicle {
  id                String        @id @default(cuid())
  vendorId          String
  vendor            VendorAccount @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  make              String
  model             String
  year              Int
  plate             String        @unique
  color             String?
  capacity          Int
  vehicleType       String
  status            String        @default("pending")
  regDoc            String?       @db.Text
  regDocName        String?
  insuranceDoc      String?       @db.Text
  insuranceDocName  String?
  roadworthyDoc     String?       @db.Text
  roadworthyDocName String?
  photoFront        String?       @db.Text
  photoSide         String?       @db.Text
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("vendor_vehicles")
}

model VendorDriver {
  id               String        @id @default(cuid())
  vendorId         String
  vendor           VendorAccount @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  fullName         String
  email            String?
  phone            String
  nationality      String?
  licenseNumber    String
  licenseExpiry    String
  status           String        @default("active")
  licenseDoc       String?       @db.Text
  licenseDocName   String?
  passportDoc      String?       @db.Text
  passportDocName  String?
  photoUrl         String?       @db.Text
  assignedVehicleId String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("vendor_drivers")
}

model VendorDocument {
  id         String        @id @default(cuid())
  vendorId   String
  vendor     VendorAccount @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  docType    String
  label      String
  fileData   String?       @db.Text
  fileName   String?
  status     String        @default("pending")
  expiryDate String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("vendor_documents")
}

model SavedCard {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  last4          String
  brand          String
  expMonth       Int
  expYear        Int
  cardholderName String?
  isDefault      Boolean  @default(false)
  stripeId       String?
  createdAt      DateTime @default(now())

  @@map("saved_cards")
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredEmail String?
  commission   Float    @default(10)
  status       String   @default("pending")
  paidAt       DateTime?
  createdAt    DateTime @default(now())

  @@map("referrals")
}

model Complaint {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  bookingRef String?
  category   String
  subject    String
  message    String    @db.Text
  status     String    @default("open")
  priority   String    @default("normal")
  response   String?   @db.Text
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("complaints")
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("available")
  vehicle   String?
  rating    Float    @default(5.0)
  trips     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("drivers")
}

model Vehicle {
  id        String   @id @default(cuid())
  type      String
  model     String
  plate     String   @unique
  status    String   @default("active")
  capacity  Int
  year      Int
  createdAt DateTime @default(now())

  @@map("vehicles")
}

model Review {
  id        String   @id @default(cuid())
  author    String
  country   String
  rating    Int
  comment   String
  service   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reviews")
}
