generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          String   @id @default(cuid())
  name        String
  iconName    String
  enabled     Boolean  @default(true)
  description String
  pricing     Json
  colorClass  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Booking {
  id               String   @id @default(cuid())
  reference        String   @unique
  status           String   @default("pending")
  serviceType      String
  pickupLocation   String
  dropoffLocation  String
  travelDate       String
  passengers       Int
  vehicleType      String
  customerName     String
  customerEmail    String
  customerWhatsapp String
  customerCountry  String
  totalAmount      Float    @default(0)
  driverId         String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("bookings")
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  status    String   @default("available")
  vehicle   String?
  rating    Float    @default(5.0)
  trips     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("drivers")
}

model Vehicle {
  id        String   @id @default(cuid())
  type      String
  model     String
  plate     String   @unique
  status    String   @default("active")
  capacity  Int
  year      Int
  createdAt DateTime @default(now())

  @@map("vehicles")
}

model Review {
  id        String   @id @default(cuid())
  author    String
  country   String
  rating    Int
  comment   String
  service   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("reviews")
}
